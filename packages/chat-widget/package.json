    "directory": "packages/chat-widget"
  },
  "devDependencies": {
    "rollup": "^4.0.0",
    "@rollup/plugin-typescript": "^11.0.0",
    "@rollup/plugin-terser": "^0.4.0",
    "typescript": "^5.0.0",
    "tslib": "^2.6.0"
  },
  "dependencies": {}
}
