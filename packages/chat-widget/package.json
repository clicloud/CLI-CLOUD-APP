{
  "name": "@clicloud/chat-widget",
  "version": "0.1.0",
  "description": "Embeddable CLI chat widget — drop-in script tag or npm package for Clide-powered support chat on any website",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "browser": "dist/widget.umd.js",
